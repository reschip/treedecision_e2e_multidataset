# .env.example - Plantilla de variables de entorno
#
# Copia este archivo a .env y edita los valores:
#   cp .env.example .env
#
# NUNCA commitees .env al repositorio (esta en .gitignore).
# En produccion (Docker / Kubernetes / Render) inyecta estas variables directamente
# en el entorno del contenedor o usa un secret manager.

# -- API -----------------------------------------------------------------------
API_VERSION=0.1.0

# -- CORS ---------------------------------------------------------------------
# Desarrollo: puedes dejar * (cualquier origen)
# Produccion: lista tus dominios reales separados por coma
ALLOWED_ORIGINS=*
# ALLOWED_ORIGINS=https://tu-frontend.com,https://admin.tu-empresa.com

# -- Rate Limiting -------------------------------------------------------------
# Formato: "N/period"  donde period = second | minute | hour | day
PREDICT_RATE_LIMIT=60/minute
INFO_RATE_LIMIT=120/minute

# -- Logging -------------------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# -- Timeouts -----------------------------------------------------------------
# Documentativo - el timeout real para conexiones entrantes lo configurara tu PaaS
REQUEST_TIMEOUT_SECONDS=30

# -- Rutas a modelos (opcional) ------------------------------------------------
# Dejar vacio para usar las rutas relativas por defecto de cada paquete.
# Util si los modelos estan en una ubicacion distinta (NFS, S3 montado, etc.)
MODELS_BASE_DIR=
